{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Backend",
            "type": "shell",
            "command": "java",
            "args": [
                "-jar",
                "${workspaceFolder}/docai/docai/target/docai-0.0.1-SNAPSHOT.jar"
            ],
            "options": {
                "cwd": "${workspaceFolder}/docai/docai"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run Backend (debug)",
            "type": "shell",
            "command": "mvn",
            "args": [
                "-e",
                "-X",
                "spring-boot:run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/docai/docai"
            },
            "problemMatcher": [
                "$maven"
            ],
            "group": "none"
        }
    ]
}